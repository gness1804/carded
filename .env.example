# Carded — Environment Variable Template
# Copy this file to .env and fill in your values before running locally.
# .env is gitignored and must never be committed.

# Owner's Anthropic API key.
# When this key is submitted via the BYOK flow, the app recognizes it as the
# owner key (via is_owner() in app.py) and skips the BYOK prompt on future visits.
# Not used as a fallback for other users — Carded is strictly bring-your-own-key.
OWNER_ANTHROPIC_API_KEY=

# Fernet encryption key for encrypting user-submitted API keys at rest in cookies.
# This must be a valid 32-byte url-safe base64-encoded Fernet key.
# Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SESSION_SECRET=

# Secret used to sign short-lived download tokens (itsdangerous).
# Use a long, randomly generated string. Do NOT reuse SESSION_SECRET.
# Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
DOWNLOAD_TOKEN_SECRET=

# Maximum file size for uploaded images, in megabytes.
# Uploads exceeding this limit will receive a 413 response.
MAX_FILE_SIZE_MB=10

# Timeout in seconds for the BAML ExtractBusinessCard() call.
# Increase this if you encounter timeout errors on slow networks or large images.
EXTRACTION_TIMEOUT_SECONDS=60

# Time-to-live in seconds for signed download tokens (/download/vcf and /download/csv).
# After this window the token is invalid and the server returns 410 Gone.
DOWNLOAD_TOKEN_TTL_SECONDS=900

# Rate limiting (Phase 6 / L2). Sliding-window, per-client-IP, in-process.
# POST /process and POST /session/key return 429 when the allowance is exceeded.
# Defaults are generous for a single-user BYOK app; tune for production traffic.
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_PROCESS=15
RATE_LIMIT_SESSION_KEY=20

# Number of trusted reverse proxies in front of the app, used to pick the
# real client IP out of X-Forwarded-For for rate limiting. Render fronts the
# app with one proxy layer, so 1 is correct for the standard deployment. If
# you add Cloudflare in front of Render, set this to 2. Set to 0 to ignore
# X-Forwarded-For entirely (direct-connection / local dev).
TRUSTED_PROXY_HOPS=1

# Decompression-bomb guard (Phase 6). Maximum pixel count (width x height) for
# HEIC/HEIF images decoded server-side before the JPEG re-encode. Images above
# this are rejected. ~50 MP covers any real phone camera.
MAX_IMAGE_PIXELS=50000000

# JPEG quality (1-95) for the HEIC -> JPEG re-encode. Higher = sharper text /
# digits for the extractor at the cost of a larger payload. 95 + no chroma
# subsampling is near-lossless; lower only if payload size becomes an issue.
JPEG_QUALITY=95
